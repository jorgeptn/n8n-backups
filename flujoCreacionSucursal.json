        "jsCode": "// 1. Obtenemos el objeto principal que llega de Slack en n8n\nconst input = $input.all()[0].json;\n\n// 2. Buscamos el texto donde está la información completa.\n// En los mensajes modernos de Slack, los detalles están dentro de \"blocks\"\nlet textoBruto = \"\";\n\nif (input.blocks && input.blocks.length > 1 && input.blocks[1].text) {\n  // Tomamos el texto del segundo bloque que contiene todos los datos\n  textoBruto = input.blocks[1].text.text; \n} else if (input.text) {\n  textoBruto = input.text;\n}\n\n// 3. Función para extraer el valor después de cada etiqueta\nconst extraerDato = (etiqueta) => {\n  const regex = new RegExp(`${etiqueta}:\\\\s*([^\\n\\r]+)`, 'i');\n  const coincidencia = textoBruto.match(regex);\n  return coincidencia ? coincidencia[1].trim() : \"\";\n};\n\n// 4. Limpiamos los correos (Slack los envía como <mailto:correo|correo>)\nconst limpiarCorreo = (correoSucio) => {\n  if (!correoSucio) return \"\";\n  const match = correoSucio.match(/mailto:([^|>]+)/);\n  return match ? match[1] : correoSucio.replace(/[<>*]/g, \"\").trim();\n};\n\n// 5. Extraemos las variables necesarias para hacer las uniones\nconst aliasExtraido = extraerDato(\"Alias\");\nconst direccionBase = extraerDato(\"Dirección\");\nconst apto = extraerDato(\"Apto/Casa/Otro\");\n\n// 6. Construimos el resultado final con el formato exacto solicitado\nconst resultado = {\n  empresa: aliasExtraido ? `AKIENVIO S.A.S/ ${aliasExtraido}` : \"AKIENVIO S.A.S\",\n  id_sucursal: \"\", // Queda básico/vacío\n  nit: \"901702784-7\",\n  contacto: \"\", // Queda vacío\n  telefono: extraerDato(\"Teléfono\"),\n  direccion: `${direccionBase} ${apto}`.trim(), // Se juntan con un espacio, sin guiones\n  ciudad: extraerDato(\"Ciudad\"),\n  email: limpiarCorreo(extraerDato(\"Usuario\")) // Extrae \"soporte@akienvio.co\" de la línea Usuario\n};\n\n// Devolvemos el array de objetos como lo espera n8n\nreturn [resultado];"
      },
