        "jsCode": "const items = $input.all();\nconst fallback = $('Validar y extraer datos').first().json;\nfor (const item of items) {\n  const j = item.json || {};\n  if (!j.telefono) j.telefono = j['TELÉFONO'] || fallback.telefono;\n  if (!j.guia) j.guia = j['Numero de guia'] || fallback.guia;\n  if (!j.ciudad) j.ciudad = j['CIUDAD'] || fallback.ciudad;\n  if (!j.telefono || !j.guia || !j.ciudad) { j.ok=false; j.stage='compose'; j.error='Faltan datos críticos (guía/ciudad/teléfono)'; continue; }\n  let telefono = String(j.telefono).replace(/\\D/g, '');\n  if (telefono.length === 10) telefono = '57' + telefono;\n  if (telefono.length < 12) { j.ok=false; j.stage='compose'; j.error='Teléfono inválido tras normalización'; continue; }\n  const oficina = j['Oficina'];\n  const conOficina = Boolean(oficina && String(oficina).trim());\n  const mensaje = conOficina\n    ? `¡Hola! Te tenemos excelentes noticias.\n\nTu paquete con guía *${j.guia}* ya se encuentra en *${j.ciudad}* y está listo para ser reclamado.\n\n*Dirección de la oficina:* ${oficina}\n\nTe invitamos a recogerlo lo más pronto posible para evitar que sea devuelto.\n\nSi deseas consultar la ubicación exacta en el mapa, puedes ingresar a este enlace:\nhttps://www3.interrapidisimo.com/SitioOficinaMasCercana/\n\nPara más información sobre tu entrega, puedes contactar directamente a Interrapidisimo al *323 255 4455*.\n\n¡Gracias por tu tiempo!`\n    : `¡Hola! Te tenemos excelentes noticias.\n\nTu paquete con guía *${j.guia}* ya se encuentra en *${j.ciudad}* y está listo para ser reclamado.\n\nPor ahora no tenemos la dirección exacta de la oficina en el sistema, pero puedes consultarla aquí:\nhttps://www3.interrapidisimo.com/SitioOficinaMasCercana/\n\nSi necesitas más información sobre la entrega, puedes comunicarte directamente con la línea de atención de Interrapidisimo al *323 255 4455*.\n\n¡Gracias por tu tiempo y que lo disfrutes!`;\n  j.ok = true;\n  j.telefono = telefono;\n  j['Mensaje a Enviar'] = mensaje;\n  j['Enlace WhatsApp'] = `https://wa.me/${telefono}?text=${encodeURIComponent(mensaje)}`;\n  j['ruta'] = conOficina ? 'con_oficina' : 'sin_oficina';\n}\nreturn items;"
      },
