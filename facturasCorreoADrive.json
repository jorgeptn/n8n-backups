      "name": "Leer correos con adjuntos",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        520,
        260
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "E6A3o0KS4UfkMlS3",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const keywords = ['factura','facturación','cufe','dian','nit'];\n\nfunction norm(s=''){\n  return s.toString().normalize('NFD').replace(/[\\u0300-\\u036f]/g,'').toLowerCase();\n}\n\nfunction emitter(from=''){\n  const m = from.match(/^\\s*\"?([^<\"]+)\"?\\s*</);\n  const raw = m ? m[1] : from.split('@')[0];\n  return raw.replace(/[^a-zA-Z0-9]+/g,' ').trim().split(/\\s+/).slice(0,3).join('-') || 'Emisor';\n}\n\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json || {};\n  const body = norm((j.textPlain || '') + '\\n' + (j.snippet || '') + '\\n' + (j.subject || ''));\n  const hasKeyword = keywords.some(k => body.includes(norm(k)));\n  const hasBinary = item.binary && Object.keys(item.binary).length > 0;\n  if (!hasKeyword || !hasBinary) continue;\n\n  const d = new Date();\n  const dd = String(d.getDate()).padStart(2,'0');\n  const mm = String(d.getMonth()+1).padStart(2,'0');\n  const yyyy = d.getFullYear();\n  const emisor = emitter(j.from || 'Emisor');\n  const folderName = `${emisor}-${dd}-${mm}-${yyyy}`;\n\n  out.push({\n    json: {\n      ...j,\n      ok: true,\n      emisor,\n      folderName,\n      targetParentFolderId: '1veOwTVWUKjs-w0DUU_GY8n8owmbUxyA-'\n    },\n    binary: item.binary\n  });\n}\n\nreturn out;"
      },
