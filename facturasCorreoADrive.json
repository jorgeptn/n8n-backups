        "jsCode": "const source = $('Filtrar facturas por body').item;\nconst folder = $json;\nconst binaries = source.binary || {};\nconst out = [];\nfor (const [k,v] of Object.entries(binaries)) {\n  out.push({\n    json: {\n      folderId: folder.id || folder.fileId || folder.folderId,\n      fileName: v.fileName || `adjunto-${k}`\n    },\n    binary: { data: v }\n  });\n}\nreturn out;"
